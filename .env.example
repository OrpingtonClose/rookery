# Rookery — environment variables

# === Model (all agents default to this) ===
# If your DeepSeek account exposes the exact model under a different
# name, change only this variable. Sub-agents inherit it.
ROOKERY_MODEL=deepseek-v4-flash
ROOKERY_BASE_URL=https://api.deepseek.com/v1
ROOKERY_API_KEY=

# DeepSeek v4 models emit reasoning tokens (returned in
# `message.reasoning_content`) that are *separate* from the answer
# tokens and both count against max_tokens. Set this high enough that
# reasoning + answer both fit. 4096 is a reasonable default for hot
# paths; tear-down workers will override.
ROOKERY_MAX_TOKENS=4096

# Override model for specific clone roles if you want a deeper thinker
# for, e.g., the Invariant Keeper. Empty = use ROOKERY_MODEL.
ROOKERY_MODEL_INVARIANT_KEEPER=
ROOKERY_MODEL_CONCURRENCY_KEEPER=
ROOKERY_MODEL_CRITIC=

# === Datalake ===
# Directory for the per-repo datalake. Gitignored by default.
ROOKERY_DATALAKE_DIR=.rookery

# === Hot-path budgets (seconds) ===
# See docs/OPERATOR_LOOP.md §3. Exceeding the budget discards the
# verdict; it does not block the operator.
ROOKERY_PREHOOK_BUDGET=10
ROOKERY_CRITIC_BUDGET=15
ROOKERY_ROUTER_BUDGET_MS=200

# === Clone size targets (tokens) ===
ROOKERY_CLONE_TARGET_TOKENS=500000
ROOKERY_CLONE_CAP_TOKENS=950000

# === Optional: local vLLM instead of DeepSeek API ===
# When set, clones are served from this vLLM instance instead of the
# remote API. Strongly recommended for the hypercloud deployment.
# ROOKERY_VLLM_BASE=http://localhost:8000/v1
# ROOKERY_VLLM_MODEL=deepseek-4-flash

# === Optional: Neo4j (Stage 4+) ===
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=

# === Observability ===
ROOKERY_LOG_LEVEL=INFO
